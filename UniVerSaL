local function createFloatingHearts()
    local hearts = {"❤️", "💖", "🌸", "✨", "💕", "🌟"}
    local items = {}
    
    for i = 1, 15 do
        local heart = Instance.new("TextLabel")
        heart.Size = UDim2.new(0, 25, 0, 25)
        heart.Position = UDim2.new(math.random(), 0, math.random(), 0)
        heart.BackgroundTransparency = 1
        heart.Text = hearts[math.random(1, #hearts)]
        heart.TextColor3 = Color3.fromRGB(255, 182, 193) -- Light pink
        heart.TextSize = math.random(15, 25)
        heart.Font = Enum.Font.GothamBold
        heart.TextTransparency = 0.3
        heart.ZIndex = 2
        heart.Parent = FloatingHearts
        
        table.insert(items, {
            label = heart,
            speedX = math.random(-20, 20) / 100,
            speedY = math.random(10, 30) / 100,
            posX = math.random(),
            posY = math.random()
        })
    end
    
    task.spawn(function()
        while ScreenGui.Parent do
            for _, item in ipairs(items) do
                item.posX = item.posX + item.speedX
                item.posY = item.posY + item.speedY
                
                if item.posX > 1 then item.posX = -0.1 end
                if item.posX < -0.1 then item.posX = 1 end
                if item.posY > 1 then item.posY = -0.1 end
                if item.posY < -0.1 then item.posY = 1 end
                
                item.label.Position = UDim2.new(item.posX, 0, item.posY, 0)
            end
            task.wait(0.1)
        end
    end)
end

task.spawn(createFloatingHearts)

-- ========== 3 FLYING CATS (random movement) ==========
local catEmojis = {"🐱", "🐈", "🐾", "😺", "😸", "😻"}
local flyingCats = {}

for i = 1, 3 do
    local cat = Instance.new("TextLabel")
    cat.Size = UDim2.new(0, 40, 0, 40)
    cat.Position = UDim2.new(math.random(), 0, math.random(), 0)
    cat.BackgroundTransparency = 1
    cat.Text = catEmojis[math.random(1, #catEmojis)]
    cat.TextColor3 = Color3.fromRGB(255, 140, 160)
    cat.TextSize = 35
    cat.Font = Enum.Font.GothamBold
    cat.ZIndex = 5
    cat.Parent = Background
    
    table.insert(flyingCats, {
        label = cat,
        speedX = (math.random(-30, 30)) / 100,
        speedY = (math.random(-20, 20)) / 100,
        posX = math.random(),
        posY = math.random(),
        rotation = 0
    })
end

task.spawn(function()
    while ScreenGui.Parent do
        for _, cat in ipairs(flyingCats) do
            cat.posX = cat.posX + cat.speedX
            cat.posY = cat.posY + cat.speedY
            
            -- Bounce off edges
            if cat.posX > 1 then 
                cat.posX = 1 - (cat.posX - 1)
                cat.speedX = -cat.speedX
            end
            if cat.posX < 0 then 
                cat.posX = -cat.posX
                cat.speedX = -cat.speedX
            end
            if cat.posY > 1 then 
                cat.posY = 1 - (cat.posY - 1)
                cat.speedY = -cat.speedY
            end
            if cat.posY < 0 then 
                cat.posY = -cat.posY
                cat.speedY = -cat.speedY
            end
            
            cat.label.Position = UDim2.new(cat.posX, 0, cat.posY, 0)
            
            -- Random slight rotation for fun
            cat.rotation = cat.rotation + 2
            cat.label.Rotation = math.sin(cat.rotation * math.pi / 180) * 10
        end
        task.wait(0.05)
    end
end)

