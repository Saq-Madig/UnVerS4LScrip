-- Matrix rain effect (falling characters) - REDUCED AMOUNT
local MatrixRain = Instance.new("Frame")
MatrixRain.Size = UDim2.new(1, 0, 1, 0)
MatrixRain.BackgroundTransparency = 1
MatrixRain.ZIndex = 2
MatrixRain.Parent = Background

local function createMatrixRain()
    -- Kurangi jumlah kolom menjadi lebih sedikit
    local columns = math.floor(workspace.CurrentCamera.ViewportSize.X / 40)
    if columns > 25 then columns = 25 end
    local drops = {}
    
    for i = 1, columns do
        local column = Instance.new("TextLabel")
        column.Size = UDim2.new(0, 20, 1, 0)
        column.Position = UDim2.new(0, i * 40, 0, 0)
        column.BackgroundTransparency = 1
        column.Text = ""
        column.TextColor3 = Color3.fromRGB(0, 255, 0)
        column.TextSize = 14
        column.Font = Enum.Font.Code
        column.TextTransparency = 0.5
        column.ZIndex = 2
        column.Parent = MatrixRain
        
        drops[i] = {
            label = column,
            y = math.random(0, 100),
            speed = math.random(3, 8),
            chars = {}
        }
    end
    
    task.spawn(function()
        while ScreenGui.Parent do
            for i, drop in ipairs(drops) do
                drop.y = drop.y + drop.speed
                if drop.y > 100 then
                    drop.y = -10
                    drop.speed = math.random(3, 8)
                end
                drop.label.Position = UDim2.new(0, i * 40, 0, drop.y)
                
                -- random matrix characters (lebih sedikit)
                local charText = ""
                for j = 1, 4 do
                    local char = string.char(math.random(33, 126))
                    charText = charText .. char .. " "
                end
                drop.label.Text = charText
            end
            task.wait(0.15)
        end
    end)
end

task.spawn(createMatrixRain)

